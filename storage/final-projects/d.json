    "criteria": [
        {
            "id": "doctype",
            "label": "Terdapat <!DOCTYPE html>",
            "aspect": "Struktur HTML",
            "file": "html",
            "points": 4,
            "tests": [
                {
                    "type": "contains",
                    "value": "<!doctype html"
                }
            ]
        },
        {
            "id": "title",
            "label": "Judul halaman (<title>) sudah diisi",
            "aspect": "Struktur HTML",
            "file": "html",
            "points": 4,
            "tests": [
                {
                    "type": "regex",
                    "value": "<title>[^<]*[a-z0-9]"
                }
            ]
        },
        {
            "id": "header",
            "label": "Terdapat <header>",
