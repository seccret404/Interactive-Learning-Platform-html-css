    "criteria": [
        {
            "id": "doctype",
            "label": "Terdapat <!DOCTYPE html>",
            "aspect": "Struktur HTML",
            "file": "html",
            "points": 4,
            "tests": [
                {
                    "type": "contains",
                    "value": "<!doctype html"
                }
            ]
        },
        {
            "id": "title",
